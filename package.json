{
  "name": "sovereign-ai-enterprise-architecture",
  "version": "1.0.0-billion-dollar-edition",
  "private": true,
  "type": "module",
  "description": "Zero-Trust Hexagonal Event-Sourced BFF CQRS Framework",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:bff": "nest start --watch",
    "build": "vite build && nest build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start:sovereign-node": "node dist/bff/main.js",
    "infra:up": "docker-compose up -d kafka redis zookeeper",
    "generate:protobuf": "pbjs -t static-module -w commonjs -o src/infrastructure/grpc/compiled.js src/infrastructure/grpc/*.proto"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@grpc/grpc-js": "^1.10.1",
    "@nestjs/common": "^10.3.3",
    "@nestjs/core": "^10.3.3",
    "@nestjs/cqrs": "^10.2.7",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.3",
    "@nestjs/platform-socket.io": "^10.3.3",
    "@nestjs/websockets": "^10.3.3",
    "@reduxjs/toolkit": "^2.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bignumber.js": "^9.1.2",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "eventemitter2": "^6.4.9",
    "express": "^4.21.2",
    "inversify": "^6.0.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "protobufjs": "^7.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.1.0",
    "redux-saga": "^1.3.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "uuid": "^9.0.1",
    "vite": "^6.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
